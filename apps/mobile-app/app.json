{
  "expo": {
    "name": "insureit",
    "slug": "insureit-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "insureit",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/aadcb7a5-072b-4bf9-bc81-c52fabdd5caa",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 10000
    },
    "icon": "./assets/brand/insureit-app-icon-ice.png",
    "splash": {
      "image": "./assets/brand/insureit-brand-wave.png",
      "resizeMode": "cover",
      "backgroundColor": "#F4F8FC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.insureit.mobile",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/insureit-app-icon-ice.png",
        "backgroundColor": "#F4F8FC"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.insureit.mobile",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/brand/insureit-app-icon-ice.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "InsureIt uses photos you select to attach accident and claim documents."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aadcb7a5-072b-4bf9-bc81-c52fabdd5caa"
      }
    },
    "owner": "antnish"
  }
}
